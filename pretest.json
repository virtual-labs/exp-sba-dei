                      {
                          "question":  "Q1. In a 5G Service-Based Architecture (SBA), what is a Service?",
                          "answers":  {
                                          "a":  "A dedicated physical connection between two network nodes",
                                          "b":  "A specific capability or function exposed by a Network Function",
                                          "c":  "A type of user equipment",
                                          "d":  "A hardware-based communication interface"
                                      },
                          "explanations":  {
                                               "a":  "Incorrect. Physical connections are not considered services in SBA.",
                                               "b":  "Correct. In SBA, a service is a specific capability or function offered by a Network Function.",
                                               "c":  "Incorrect. User Equipment (UE) is not part of SBA service definition.",
                                               "d":  "Incorrect. Services are logical, not hardware-based."
                                           },
                          "correctAnswer":  "b",
                          "difficulty":  "beginner"
                      },
                      {
                          "question":  "Q2. Which of the following acts as a Service Producer in SBA?",
